@page
@model CondiService.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = "/Pages/Shared/_Layout.cshtml";
}


<div class="auth-wrap">
  <div class="card auth-card">
    <div class="card-body">
      <div class="auth-hero">
        <div class="auth-icon"></div>
        <div>
          <h1 class="auth-title">Вход</h1>
          <div class="auth-note">Доступ по ролям: менеджер, оператор, специалист, заказчик</div>
        </div>
      </div>

<div class="card" style="max-width:420px;margin:0 auto;">
    <h1 class="h2">Вход</h1>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert--danger">@Model.ErrorMessage</div>
    }

    <form method="post" class="form">
        <label class="field">
            <span class="field__label">Логин</span>
            <input class="input" asp-for="Input.Login" autocomplete="username" />
            <span class="field__error" asp-validation-for="Input.Login"></span>
        </label>

        <label class="field">
            <span class="field__label">Пароль</span>
            <input class="input" asp-for="Input.Password" type="password" autocomplete="current-password" />
            <span class="field__error" asp-validation-for="Input.Password"></span>
        </label>

        <label class="check">
            <input asp-for="Input.RememberMe" />
            <span>Запомнить меня</span>
        </label>

        <button class="btn" type="submit">Войти</button>

        <div class="muted" style="margin-top:12px;">
            Данные для входа импортируются автоматически: <b>login1/pass1</b>, <b>login2/pass2</b> и т.д.
        </div>
    </form>
</div>

    </div>
  </div>
</div>
