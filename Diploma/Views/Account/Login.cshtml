@model EmployeeManagementApp.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="center-screen">
    <section class="auth-window">
        <h1 class="auth-title">Вход</h1>
        <p class="auth-subtitle">Используйте учетную запись администратора или созданный профиль.</p>

        <form asp-action="Login" method="post" class="form-vertical">
            <div class="form-row">
                <label asp-for="Username"></label>
                <input asp-for="Username" class="input" autocomplete="username" />
                <span asp-validation-for="Username" class="validation"></span>
            </div>
            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="validation"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Войти</button>

            <p class="auth-hint">
                Логин по умолчанию: <b>admin</b>, пароль: <b>admin123</b>. 
                <a asp-action="Register">Создать новый аккаунт</a>
            </p>
        </form>

        <div class="validation-summary">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
