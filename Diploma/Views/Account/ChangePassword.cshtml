@model EmployeeManagementApp.Controllers.ChangePasswordViewModel
@{
    ViewData["Title"] = "Смена пароля";
}

<section class="page-header">
    <div>
        <h1>Смена пароля</h1>
        <p class="page-subtitle">Обновите пароль для повышения безопасности.</p>
    </div>
</section>

<section class="card">
    <form asp-action="ChangePassword" method="post" class="form-vertical">
        <div class="form-row">
            <label asp-for="CurrentPassword"></label>
            <input asp-for="CurrentPassword" class="input" autocomplete="current-password" />
            <span asp-validation-for="CurrentPassword" class="validation"></span>
        </div>
        <div class="form-row">
            <label asp-for="NewPassword"></label>
            <input asp-for="NewPassword" class="input" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="validation"></span>
        </div>
        <div class="form-row">
            <label asp-for="ConfirmNewPassword"></label>
            <input asp-for="ConfirmNewPassword" class="input" autocomplete="new-password" />
            <span asp-validation-for="ConfirmNewPassword" class="validation"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-action="Profile" class="btn btn-ghost">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
